---
import { siteConfig } from '../data/site.config';
const currentYear = new Date().getFullYear();
---
<section id="about" class="section-padding bg-navy-950 text-white">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="animate-on-scroll">
        <span class="inline-block font-display text-gold-400 text-sm font-bold uppercase tracking-widest mb-4">
          About the Mississippi Sports App
        </span>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight">
          The Mississippi Sports App — Trusted Coverage Since {siteConfig.founder.yearFounded}
        </h2>
        <div class="space-y-4 text-gray-300 leading-relaxed">
          <p>
            The Mississippi Sports App was built by <strong class="text-white">{siteConfig.founder.name}</strong>, a veteran Mississippi sports journalist, to put every high school and college score, story, and standout play right in your pocket.
          </p>
          <p>
            Backed by Mississippi Sports Group — a statewide digital network spanning multiple counties and communities — the Mississippi Sports App delivers the coverage that matters most. From Friday night football under the lights in Tippah County to NCAA matchups in the Delta, it's all here in one free app.
          </p>
          <p>
            Download the Mississippi Sports App today and join thousands of fans who rely on it for trusted, local sports journalism across the Magnolia State.
          </p>
        </div>
      </div>

      <!-- Stats / Trust Badges -->
      <div class="animate-on-scroll" style="animation-delay: 0.15s;">
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-navy-900/50 border border-navy-800 rounded-2xl p-6 text-center">
            <div class="font-display text-4xl md:text-5xl font-bold text-gold-400 mb-2">
              {currentYear - siteConfig.founder.yearFounded}+
            </div>
            <div class="text-sm text-gray-400 uppercase tracking-wider font-display">Years of Coverage</div>
          </div>
          <div class="bg-navy-900/50 border border-navy-800 rounded-2xl p-6 text-center">
            <div class="font-display text-4xl md:text-5xl font-bold text-gold-400 mb-2">6+</div>
            <div class="text-sm text-gray-400 uppercase tracking-wider font-display">Publications</div>
          </div>
          <div class="bg-navy-900/50 border border-navy-800 rounded-2xl p-6 text-center">
            <div class="font-display text-4xl md:text-5xl font-bold text-gold-400 mb-2">100%</div>
            <div class="text-sm text-gray-400 uppercase tracking-wider font-display">Mississippi Focused</div>
          </div>
          <div class="bg-navy-900/50 border border-navy-800 rounded-2xl p-6 text-center">
            <div class="font-display text-4xl md:text-5xl font-bold text-gold-400 mb-2">Free</div>
            <div class="text-sm text-gray-400 uppercase tracking-wider font-display">On the App Store</div>
          </div>
        </div>

        <div class="mt-6 p-4 bg-navy-900/30 border border-navy-800 rounded-xl flex items-center gap-4">
          <img src="/logo.png" alt="Mississippi Sports App" class="h-12 w-auto" width="48" height="48" loading="lazy" />
          <div>
            <p class="text-white font-display font-bold text-sm uppercase">Founded by {siteConfig.founder.name}</p>
            <p class="text-gray-400 text-xs">{siteConfig.founder.title} · Veteran Mississippi Sports Journalist</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
